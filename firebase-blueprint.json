{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product categories for the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "parentId": { "type": "string" },
        "sortOrder": { "type": "number" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "Stationery products available for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "mrp": { "type": "number" },
        "gstRate": { "type": "number" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "categoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "price", "categoryId", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "total": { "type": "number" },
        "gstAmount": { "type": "number" },
        "shippingCharge": { "type": "number" },
        "grandTotal": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed", "refunded"] },
        "paymentMethod": { "type": "string", "enum": ["cod", "upi", "card"] },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "userId", "status", "grandTotal"]
    },
    "User": {
      "title": "User",
      "description": "Customer and Admin profiles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
