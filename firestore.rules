rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: bootstrapped with owner email or role lookup
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'rohan00as@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRODUCTS ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
      
      function isValidProduct(p) {
        return p.keys().hasAll(['name', 'price', 'image', 'slug']) &&
               p.name is string && p.name.size() > 0 && p.name.size() < 200 &&
               p.price is number && p.price >= 0 &&
               p.image is string && p.image.size() > 0 &&
               p.slug is string && p.slug.matches('^[a-z0-9-]+$') &&
               (!('description' in p) || p.description is string) &&
               (!('category' in p) || p.category is string) &&
               (!('stock' in p) || p.stock is number);
      }
    }

    // --- CATEGORIES ---
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
      
      function isValidCategory(c) {
        return c.keys().hasAll(['name', 'image']) &&
               c.name is string && c.name.size() > 0 &&
               c.image is string && c.image.size() > 0;
      }
    }

    // --- BANNERS ---
    match /banners/{bannerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBanner(incoming());
      allow update: if isAdmin() && isValidBanner(incoming());
      allow delete: if isAdmin();
      
      function isValidBanner(b) {
        return b.keys().hasAll(['image', 'order']) &&
               b.image is string && b.order is number;
      }
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidOrder(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isAdmin() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      
      function isValidOrder(o) {
        return o.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
               o.userId is string &&
               o.items is list && o.items.size() > 0 &&
               o.total is number && o.total >= 0 &&
               o.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
               o.createdAt is timestamp;
      }
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if (isOwner(userId) && incoming().role == existing().role && isValidUser(incoming())) || isAdmin();
      
      function isValidUser(u) {
        return u.keys().hasAll(['email', 'role', 'createdAt']) &&
               u.email is string && u.email == request.auth.token.email &&
               u.role in ['customer', 'admin'] &&
               u.createdAt is string;
      }
    }
  }
}
